"res://project/scripts/levels_gd/": "yellow",
"res://project/scripts/player_gd/": "green",
"res://project/scripts/popups_gd/": "purple",
"res://project/scripts/spell_gd/": "teal",
"res://project/scripts/wands_gd/": "blue",
"res://project/tilesets/": "gray"
}

