; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NoitaClone"
config/features=PackedStringArray("4.6", "Forward Plus")

[display]

window/size/viewport_width=426
window/size/viewport_height=240
window/size/window_width_override=1080
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://project/": "gray",
"res://project/resources/spells_tres/": "teal",
"res://project/resources/wands_tres/": "blue",
"res://project/scenes/enemies_tscn/": "red",
"res://project/scenes/levels_tscn/": "yellow",
"res://project/scenes/player_tscn/": "green",
"res://project/scenes/popups_tscn/": "purple",
"res://project/scenes/spell_tscn/": "teal",
"res://project/scenes/wand_tscn/": "blue",
